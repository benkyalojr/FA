# Route all /api/* requests through the front controller (Apache deployment).
RewriteEngine On
RewriteBase /api/

# Serve real files (e.g. uploaded photos) directly.
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Otherwise dispatch to index.php.
RewriteRule ^ index.php [QSA,L]
